{
  "manifest_version": 3,
  "name": "BranchScope for Claude",
  "version": "1.0.0",
  "description": "Visualize and explore Claude.ai conversation trees with branching history",
  "permissions": ["activeTab", "scripting", "cookies", "tabs"],
  "host_permissions": ["https://claude.ai/*"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/chat/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "BranchScope for Claude"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
